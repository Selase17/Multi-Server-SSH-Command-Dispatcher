# =============================================================================
# servers.conf.example — Template for dispatcher.sh
# =============================================================================
# Copy this file to servers.conf and replace the placeholder values with
# your real server details before running dispatcher.sh.
#
#   cp servers.conf.example servers.conf
#
# Format:  HOSTNAME   IP_ADDRESS   SSH_USER
#
# - HOSTNAME  : any label you want — shown in output blocks, not used by SSH
# - IP_ADDRESS: the address SSH will connect to (IPv4, IPv6, or resolvable hostname)
# - SSH_USER  : the remote user — must have your public key in ~/.ssh/authorized_keys
#
# Prerequisites before adding a server here:
#   1. Generate a key pair if you don't have one:
#        ssh-keygen -t ed25519 -C "dispatcher"
#   2. Copy your public key to the server:
#        ssh-copy-id -i ~/.ssh/id_ed25519.pub <user>@<ip>
#   3. Test the connection manually:
#        ssh -o BatchMode=yes <user>@<ip> 'echo ok'
#      If that prints "ok" without a password prompt, the server is ready.
# =============================================================================

# --- Example entries (replace with your own) ---------------------------------
# HOSTNAME        IP_ADDRESS       SSH_USER
web-01            <ip-address>     <ssh-user>
web-02            <ip-address>     <ssh-user>
db-01             <ip-address>     <ssh-user>

# --- Local test entry (SSH to your own machine) ------------------------------
# Useful for verifying the script works before pointing it at real servers.
# Requires: ssh localhost to work without a password prompt.
# localhost         127.0.0.1        <your-username>
